# ============================================================
# ExamVerify — Environment Variables
# Copy this file to .env.local and fill in your values.
# In Vercel: add these under Project → Settings → Environment Variables.
# ============================================================

# --- Supabase (Frontend + Backend) ---
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# --- Supabase Service Role (Vercel API function ONLY — never expose to browser) ---
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- QR Encryption Secret (Frontend) ---
# Any long random string — used to encrypt QR code payloads with AES-256
VITE_QR_SECRET_KEY=change-me-to-a-long-random-secret-string

# --- Remita Payment Gateway (Vercel API function ONLY) ---
# Your Remita secret/API key from the Remita merchant portal
REMITA_SECRET_KEY=your-remita-secret-key-here

# --- Google OAuth (optional — configure in Supabase Auth settings, not here) ---
# Google OAuth is configured in Supabase Dashboard → Authentication → Providers → Google
# You do NOT need to set Google client ID/secret here; Supabase handles it.
